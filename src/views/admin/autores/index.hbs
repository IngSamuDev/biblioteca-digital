<div class="min-h-screen bg-gray-50">

    <div class="bg-white border-b border-gray-200">
        <div class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
            <div class="flex items-center gap-4">
                {{#if esAdmin}}
                <a href="/admin/dashboard"
                    class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-600 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                {{else}}
                <a href="/biblioteca/dashboard"
                    class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-600 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </a>
                {{/if}}
                <div>
                    <h1 class="text-xl font-bold text-gray-900">Gestión de Autores</h1>
                    <p class="text-gray-400 text-sm mt-0.5">Administra los autores del catálogo</p>
                </div>
            </div>
            <a href="/admin/autores/nuevo"
                class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition shadow-sm shadow-blue-200">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Nuevo autor
            </a>
        </div>
    </div>

    <div class="max-w-5xl mx-auto px-6 py-8">

        {{#if success}}
        <div
            class="bg-green-50 border border-green-200 text-green-700 rounded-2xl px-5 py-3.5 mb-6 text-sm flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" />
            </svg>
            Operación realizada correctamente
        </div>
        {{/if}}

        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-gray-100">
                            <th class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">
                                Nombre</th>
                            <th
                                class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide hidden md:table-cell">
                                Nacionalidad</th>
                            <th
                                class="text-left px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide hidden sm:table-cell">
                                Libros</th>
                            <th
                                class="text-right px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wide">
                                Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        {{#each autores}}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div
                                        class="w-9 h-9 rounded-xl bg-purple-100 flex items-center justify-center text-purple-600 font-bold text-sm uppercase flex-shrink-0">
                                        {{ nombre_autores.[0] }}
                                    </div>
                                    <span class="text-sm font-semibold text-gray-900">{{ nombre_autores }}</span>
                                </div>
                            </td>
                            <td class="px-6 py-4 hidden md:table-cell">
                                <span class="text-sm text-gray-500">{{ nacionalidad_autores }}</span>
                            </td>
                            <td class="px-6 py-4 hidden sm:table-cell">
                                <span class="text-xs bg-purple-50 text-purple-600 px-2.5 py-1 rounded-lg font-medium">{{
                                    total_libros }} libros</span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a href="/admin/autores/{{ id_autores }}/editar"
                                        class="text-xs font-medium text-gray-600 hover:text-blue-600 bg-gray-100 hover:bg-blue-50 px-3 py-1.5 rounded-lg transition">
                                        Editar
                                    </a>
                                    <form action="/admin/autores/{{ id_autores }}/eliminar" method="POST"
                                        onsubmit="return confirm('¿Eliminar este autor?')">
                                        <button type="submit"
                                            class="text-xs font-medium text-red-500 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition">
                                            Eliminar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {{else}}
                        <tr>
                            <td colspan="4" class="px-6 py-16 text-center">
                                <div
                                    class="w-14 h-14 bg-gray-100 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-3">
                                    ✍️</div>
                                <p class="text-gray-500 font-medium text-sm">No hay autores registrados</p>
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>