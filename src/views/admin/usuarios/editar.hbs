<div class="min-h-screen bg-gray-50">

    <div class="bg-white border-b border-gray-200">
        <div class="max-w-2xl mx-auto px-6 py-5 flex items-center gap-4">
            <a href="/admin/usuarios"
                class="w-9 h-9 flex items-center justify-center rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </a>
            <div>
                <h1 class="text-xl font-bold text-gray-900">Editar Usuario</h1>
                <p class="text-gray-400 text-sm mt-0.5">{{ usuarioEditar.email_usuarios }}</p>
            </div>
        </div>
    </div>

    <div class="max-w-2xl mx-auto px-6 py-8">

        {{#if error}}
        <div
            class="bg-red-50 border border-red-200 text-red-600 rounded-2xl px-5 py-3.5 mb-6 text-sm flex items-center gap-2">
            <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" />
            </svg>
            {{ error }}
        </div>
        {{/if}}

        <div class="bg-white rounded-2xl border border-gray-100 p-8">
            <form action="/admin/usuarios/{{ usuarioEditar.id_usuarios }}/editar" method="POST" class="space-y-5">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nombre completo <span
                            class="text-red-400">*</span></label>
                    <input type="text" name="nombre" value="{{ usuarioEditar.nombre_usuarios }}" required
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-gray-50 focus:bg-white" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Email <span
                            class="text-red-400">*</span></label>
                    <input type="email" name="email" value="{{ usuarioEditar.email_usuarios }}" required
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-gray-50 focus:bg-white" />
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nueva contraseña</label>
                    <input type="password" name="password" placeholder="Dejar vacío para no cambiar"
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-gray-50 focus:bg-white" />
                    <p class="text-gray-400 text-xs mt-1.5">Mínimo 6 caracteres si deseas cambiarla</p>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Rol <span
                            class="text-red-400">*</span></label>
                    <select name="id_roles" required
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-gray-50 focus:bg-white">
                        {{#each roles}}
                        <option value="{{ id_roles }}" {{#if seleccionado}}selected{{/if}}>{{ nombre_roles }}</option>
                        {{/each}}
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Estado</label>
                    <select name="estado"
                        class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition bg-gray-50 focus:bg-white">
                        <option value="true" {{#if usuarioEditar.estado_usuarios}}selected{{/if}}>Activo</option>
                        <option value="false" {{#unless usuarioEditar.estado_usuarios}}selected{{/unless}}>Inactivo
                        </option>
                    </select>
                </div>
                <div class="flex gap-3 pt-2">
                    <button type="submit"
                        class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition text-sm shadow-sm shadow-blue-200">
                        Guardar cambios
                    </button>
                    <a href="/admin/usuarios"
                        class="flex-1 text-center border border-gray-200 hover:bg-gray-50 text-gray-600 font-semibold py-3 rounded-xl transition text-sm">
                        Cancelar
                    </a>
                </div>
            </form>
        </div>

    </div>
</div>