<div class="max-w-3xl mx-auto px-4 py-8">

    <div class="flex items-center gap-3 mb-6">
        {{#if esAdmin}}
        <a href="/admin/libros"
            class="border border-gray-300 hover:bg-gray-50 text-gray-600 text-sm font-semibold px-4 py-2 rounded-xl transition">
            ← Volver
        </a>
        {{else}}
        <a href="/admin/libros"
            class="border border-gray-300 hover:bg-gray-50 text-gray-600 text-sm font-semibold px-4 py-2 rounded-xl transition">
            ← Volver
        </a>
        {{/if}}
        <h1 class="text-2xl font-bold text-gray-800">📤 Subir Nuevo Libro</h1>
    </div>

    {{#if error}}
    <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-5 text-sm flex items-center gap-2">
        <span>❌</span> {{ error }}
    </div>
    {{/if}}

    <div class="bg-white rounded-2xl shadow p-8">
        <form action="/admin/libros/nuevo" method="POST" enctype="multipart/form-data" class="space-y-6">

            <!-- Título -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    Título <span class="text-red-500">*</span>
                </label>
                <input type="text" name="titulo" required placeholder="Título del libro"
                    class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <p class="text-xs text-gray-400 mt-1">Máximo 200 caracteres</p>
            </div>

            <!-- Descripción -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
                <textarea name="descripcion" rows="4" placeholder="Descripción del libro..."
                    class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"></textarea>
            </div>

            <!-- Año -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Año de publicación</label>
                <input type="number" name="anio" min="1000" max="2099" placeholder="Ej: 2023"
                    class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
                <p class="text-xs text-gray-400 mt-1">Entre 1000 y {{ currentYear }}</p>
            </div>

            <!-- Autores -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Autores</label>
                {{#if autores.length}}
                <div
                    class="grid grid-cols-2 gap-2 max-h-40 overflow-y-auto border border-gray-200 rounded-xl p-3 bg-gray-50">
                    {{#each autores}}
                    <label class="flex items-center gap-2 text-sm cursor-pointer hover:text-blue-600 transition">
                        <input type="checkbox" name="autores" value="{{ id_autores }}"
                            class="rounded border-gray-300 text-blue-600" />
                        {{ nombre_autores }}
                    </label>
                    {{/each}}
                </div>
                {{else}}
                <div class="border border-dashed border-gray-300 rounded-xl p-4 text-center">
                    <p class="text-gray-400 text-sm">No hay autores registrados.</p>
                    <a href="/admin/autores/nuevo" class="text-blue-600 hover:underline text-sm font-medium">
                        + Crear autor
                    </a>
                </div>
                {{/if}}
            </div>

            <!-- Categorías -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Categorías</label>
                {{#if categorias.length}}
                <div
                    class="grid grid-cols-2 gap-2 max-h-40 overflow-y-auto border border-gray-200 rounded-xl p-3 bg-gray-50">
                    {{#each categorias}}
                    <label class="flex items-center gap-2 text-sm cursor-pointer hover:text-blue-600 transition">
                        <input type="checkbox" name="categorias" value="{{ id_categorias }}"
                            class="rounded border-gray-300 text-blue-600" />
                        {{ nombre_categorias }}
                    </label>
                    {{/each}}
                </div>
                {{else}}
                <div class="border border-dashed border-gray-300 rounded-xl p-4 text-center">
                    <p class="text-gray-400 text-sm">No hay categorías registradas.</p>
                    <a href="/admin/categorias/nuevo" class="text-blue-600 hover:underline text-sm font-medium">
                        + Crear categoría
                    </a>
                </div>
                {{/if}}
            </div>

            <!-- PDF -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">
                    Archivo PDF <span class="text-red-500">*</span>
                </label>
                <div class="border-2 border-dashed border-gray-300 rounded-xl p-4 hover:border-blue-400 transition">
                    <input type="file" name="pdf" accept=".pdf" required
                        class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-600 hover:file:bg-blue-100 transition" />
                </div>
                <p class="text-xs text-gray-400 mt-1">Solo archivos PDF. Máximo 50MB.</p>
            </div>

            <!-- Portada -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Portada (imagen)</label>
                <div class="border-2 border-dashed border-gray-300 rounded-xl p-4 hover:border-blue-400 transition">
                    <input type="file" name="portada" accept="image/*"
                        class="w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-green-50 file:text-green-600 hover:file:bg-green-100 transition" />
                </div>
                <p class="text-xs text-gray-400 mt-1">Opcional. JPG, PNG o WEBP recomendado.</p>
            </div>

            <!-- Botones -->
            <div class="flex gap-3 pt-2 border-t border-gray-100">
                <button type="submit"
                    class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-2.5 rounded-xl transition text-sm shadow-sm shadow-blue-200">
                    📤 Subir libro
                </button>
                <a href="/admin/libros"
                    class="flex-1 text-center border border-gray-300 hover:bg-gray-50 text-gray-600 font-semibold px-6 py-2.5 rounded-xl transition text-sm">
                    Cancelar
                </a>
            </div>

        </form>
    </div>
</div>