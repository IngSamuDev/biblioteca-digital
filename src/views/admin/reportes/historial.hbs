<div class="max-w-5xl mx-auto px-4 py-8">

    <div class="flex items-center gap-3 mb-6">
        <a href="/admin/reportes"
            class="border border-gray-300 hover:bg-gray-50 text-gray-600 text-sm font-semibold px-4 py-2 rounded-lg transition">
            ← Volver
        </a>
        <div>
            <h1 class="text-2xl font-bold text-gray-800">📋 Historial de actividad</h1>
            <p class="text-gray-500 text-sm mt-1">
                {{ usuarioVer.nombre_usuarios }} — {{ usuarioVer.email_usuarios }}
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <!-- Descargas -->
        <div class="bg-white rounded-xl shadow p-6">
            <h2 class="font-bold text-gray-800 mb-4">⬇️ Descargas ({{ descargas.length }})</h2>
            {{#if descargas.length}}
            <div class="space-y-3">
                {{#each descargas}}
                <div class="py-2 border-b border-gray-100 last:border-0">
                    <p class="text-sm font-medium text-gray-800">{{ titulo_libros }}</p>
                    {{#if autores}}
                    <p class="text-xs text-blue-600">{{ autores }}</p>
                    {{/if}}
                    <p class="text-xs text-gray-400 mt-1">{{ fecha_descarga_descargas }}</p>
                </div>
                {{/each}}
            </div>
            {{else}}
            <p class="text-gray-400 text-sm text-center py-4">Sin descargas</p>
            {{/if}}
        </div>

        <!-- Visualizaciones -->
        <div class="bg-white rounded-xl shadow p-6">
            <h2 class="font-bold text-gray-800 mb-4">👁️ Lecturas ({{ visualizaciones.length }})</h2>
            {{#if visualizaciones.length}}
            <div class="space-y-3">
                {{#each visualizaciones}}
                <div class="py-2 border-b border-gray-100 last:border-0">
                    <p class="text-sm font-medium text-gray-800">{{ titulo_libros }}</p>
                    {{#if autores}}
                    <p class="text-xs text-blue-600">{{ autores }}</p>
                    {{/if}}
                    <p class="text-xs text-gray-400 mt-1">{{ fecha_visualizacion_visualizaciones }}</p>
                </div>
                {{/each}}
            </div>
            {{else}}
            <p class="text-gray-400 text-sm text-center py-4">Sin lecturas</p>
            {{/if}}
        </div>

    </div>
</div>