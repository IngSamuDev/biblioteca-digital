<!-- Hero Section -->
<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-blue-950 to-slate-900 text-white">
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-10 left-10 w-72 h-72 bg-blue-500 rounded-full filter blur-3xl"></div>
        <div class="absolute bottom-10 right-10 w-96 h-96 bg-indigo-500 rounded-full filter blur-3xl"></div>
    </div>
    <div class="relative max-w-5xl mx-auto px-4 py-24 text-center">
        <div
            class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm text-blue-200 mb-6">
            📚 Tu biblioteca digital favorita
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold mb-5 leading-tight tracking-tight">
            Descubre tu próximo<br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">libro
                favorito</span>
        </h1>
        <p class="text-slate-300 text-lg md:text-xl mb-10 max-w-xl mx-auto leading-relaxed">
            Miles de libros digitales al alcance de tu mano. Lee, descarga y explora sin límites.
        </p>
        {{#if estaLogueado}}
        <a href="/catalogo"
            class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3.5 rounded-2xl transition shadow-lg shadow-blue-900/50 text-base">
            Explorar catálogo completo
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </a>
        {{else}}
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/auth/registro"
                class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold px-8 py-3.5 rounded-2xl transition shadow-lg shadow-blue-900/50 text-base">
                Crear cuenta gratis
            </a>
            <a href="/auth/login"
                class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur-sm border border-white/20 text-white font-semibold px-8 py-3.5 rounded-2xl transition text-base">
                Iniciar sesión
            </a>
        </div>
        {{/if}}
    </div>
</section>

<!-- Stats -->
<section class="bg-white border-b border-gray-100">
    <div class="max-w-5xl mx-auto px-4 py-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="text-center p-4">
                <div class="text-3xl font-extrabold text-blue-600 mb-1">{{ stats.total_libros }}</div>
                <div class="text-gray-400 text-xs font-medium uppercase tracking-wide">Libros</div>
            </div>
            <div class="text-center p-4">
                <div class="text-3xl font-extrabold text-indigo-600 mb-1">{{ stats.total_autores }}</div>
                <div class="text-gray-400 text-xs font-medium uppercase tracking-wide">Autores</div>
            </div>
            <div class="text-center p-4">
                <div class="text-3xl font-extrabold text-violet-600 mb-1">{{ stats.total_categorias }}</div>
                <div class="text-gray-400 text-xs font-medium uppercase tracking-wide">Categorías</div>
            </div>
            <div class="text-center p-4">
                <div class="text-3xl font-extrabold text-blue-600 mb-1">{{ stats.total_usuarios }}</div>
                <div class="text-gray-400 text-xs font-medium uppercase tracking-wide">Lectores</div>
            </div>
        </div>
    </div>
</section>

<!-- Catálogo -->
<section class="max-w-7xl mx-auto px-4 py-14">

    <div class="flex items-end justify-between mb-8">
        <div>
            <p class="text-blue-600 text-sm font-semibold uppercase tracking-wide mb-1">Catálogo</p>
            <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900">Últimos libros agregados</h2>
        </div>
        {{#if estaLogueado}}
        <a href="/catalogo"
            class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-blue-600 hover:text-blue-700 transition">
            Ver catálogo completo
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
        </a>
        {{/if}}
    </div>

    {{#if libros.length}}

    <!-- Grid — 6 columnas, máximo 6 filas visibles (36 libros) -->
    <div id="gridLibros" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {{#each libros}}
        <div class="libro-card {{#if @index}}{{#if (gte @index 12)}}hidden-card hidden{{/if}}{{/if}}
                    group bg-white rounded-2xl border border-gray-100 hover:border-blue-200
                    hover:shadow-lg transition-all duration-300 overflow-hidden flex flex-col
                    cursor-pointer hover:-translate-y-1">

            {{#if ../estaLogueado}}
            <a href="/catalogo/{{ id_libros }}" class="flex flex-col flex-1">
                {{else}}
                <div onclick="mostrarModalLogin()" class="flex flex-col flex-1">
                    {{/if}}

                    <!-- Portada -->
                    <div class="relative aspect-[2/3] overflow-hidden bg-gray-100">
                        {{#if portada}}
                        <img src="{{ portada }}" alt="{{ titulo_libros }}"
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        {{else}}
                        <div class="w-full h-full flex flex-col items-center justify-center text-gray-300">
                            <div class="text-4xl mb-1">📕</div>
                            <p class="text-xs">Sin portada</p>
                        </div>
                        {{/if}}
                        <!-- Overlay hover -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent
                          opacity-0 group-hover:opacity-100 transition-opacity duration-300
                          flex items-end p-2">
                            {{#if ../estaLogueado}}
                            <span
                                class="text-white text-xs font-semibold bg-blue-600 px-2 py-1 rounded-lg w-full text-center">
                                Ver libro →
                            </span>
                            {{else}}
                            <span
                                class="text-white text-xs font-semibold bg-black/40 backdrop-blur-sm px-2 py-1 rounded-lg w-full text-center">
                                🔒 Inicia sesión
                            </span>
                            {{/if}}
                        </div>
                    </div>

                    <!-- Info -->
                    <div class="p-2.5 flex flex-col flex-1">
                        <h3 class="font-semibold text-gray-900 text-xs leading-snug mb-1 line-clamp-2
                         group-hover:text-blue-600 transition-colors">
                            {{ titulo_libros }}
                        </h3>
                        {{#if autores}}
                        <p class="text-gray-400 text-xs truncate">{{ autores }}</p>
                        {{/if}}
                    </div>

                    {{#if ../estaLogueado}}
            </a>
            {{else}}
        </div>
        {{/if}}

    </div>
    {{/each}}
    </div>

    <!-- Botón ver más — aparece si hay más de 12 libros -->
    {{#if libros.length}}
    <div id="btnVerMas" class="text-center mt-10 {{#if (lte libros.length 12)}}hidden{{/if}}">
        <button onclick="verMasLibros()" class="inline-flex items-center gap-2 border border-gray-200 hover:border-blue-300
                       hover:bg-blue-50 text-gray-700 hover:text-blue-600 font-medium px-8 py-3
                       rounded-2xl transition text-sm">
            Ver más libros
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
        </button>
    </div>
    {{/if}}

    {{else}}
    <div class="text-center py-24">
        <div class="w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center text-4xl mx-auto mb-4">📭</div>
        <p class="text-gray-600 font-semibold text-lg">Aún no hay libros</p>
        <p class="text-gray-400 text-sm mt-1">El administrador puede subir libros desde el panel</p>
    </div>
    {{/if}}

</section>

<!-- Modal login -->
<div id="modalLogin" class="fixed inset-0 bg-black/50 backdrop-blur-sm hidden items-center justify-center z-50 px-4">
    <div class="bg-white rounded-3xl shadow-2xl max-w-sm w-full p-8 text-center">
        <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center text-3xl mx-auto mb-4">🔒</div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Acceso restringido</h3>
        <p class="text-gray-500 text-sm mb-6 leading-relaxed">
            Inicia sesión o crea una cuenta para acceder al catálogo completo.
        </p>
        <div class="flex flex-col gap-3">
            <a href="/auth/login"
                class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition text-sm">
                Iniciar sesión
            </a>
            <a href="/auth/registro"
                class="border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold py-3 rounded-xl transition text-sm">
                Crear cuenta gratis
            </a>
            <button onclick="cerrarModal()" class="text-gray-400 hover:text-gray-600 text-sm transition pt-1">
                Cancelar
            </button>
        </div>
    </div>
</div>

<script>
    // ── Modal ─────────────────────────────────────────────────────
    function mostrarModalLogin() {
        const modal = document.getElementById('modalLogin');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }
    function cerrarModal() {
        const modal = document.getElementById('modalLogin');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }
    document.getElementById('modalLogin').addEventListener('click', function (e) {
        if (e.target === this) cerrarModal();
    });

    // ── Ver más libros ────────────────────────────────────────────
    let librosVisibles = 12;
    const incremento = 12;

    function verMasLibros() {
        const cards = document.querySelectorAll('.hidden-card');
        let mostrados = 0;

        cards.forEach(card => {
            if (mostrados < incremento) {
                card.classList.remove('hidden');
                card.classList.remove('hidden-card');
                mostrados++;
            }
        });

        // Si ya no quedan cards ocultas, esconder el botón
        const restantes = document.querySelectorAll('.hidden-card');
        if (restantes.length === 0) {
            document.getElementById('btnVerMas').classList.add('hidden');
        }
    }
</script>