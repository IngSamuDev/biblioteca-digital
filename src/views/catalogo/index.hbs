<div class="min-h-screen bg-gray-50">

    <!-- Header -->
    <div class="bg-white border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
            <div>
                <h1 class="text-xl font-bold text-gray-900">Catálogo de Libros</h1>
                <p class="text-gray-400 text-sm mt-0.5">{{ totalLibros }} libros disponibles</p>
            </div>
            <a href="/"
                class="text-sm font-medium text-gray-500 hover:text-gray-900 transition px-4 py-2 rounded-xl hover:bg-gray-100">
                ← Inicio
            </a>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-8">

        <!-- Filtros -->
        <form method="GET" action="/catalogo"
            class="bg-white rounded-2xl border border-gray-100 p-5 mb-8 flex flex-col md:flex-row gap-3">
            <div class="flex-1 relative">
                <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-300" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" />
                </svg>
                <input type="text" name="buscar" value="{{ buscar }}" placeholder="Buscar por título o autor..."
                    class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" />
            </div>
            <select name="categoria"
                class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition bg-white min-w-[180px]">
                <option value="">Todas las categorías</option>
                {{#each categorias}}
                <option value="{{ id_categorias }}" {{#if (eq (toString id_categorias)
                    ../categoriaSeleccionada)}}selected{{/if}}>
                    {{ nombre_categorias }}
                </option>
                {{/each}}
            </select>
            <select name="ordenar"
                class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 transition bg-white min-w-[160px]">
                <option value="fecha_desc" {{#if (eq ordenar 'fecha_desc' )}}selected{{/if}}>Más recientes</option>
                <option value="fecha_asc" {{#if (eq ordenar 'fecha_asc' )}}selected{{/if}}>Más antiguos</option>
                <option value="titulo_asc" {{#if (eq ordenar 'titulo_asc' )}}selected{{/if}}>A — Z</option>
                <option value="titulo_desc" {{#if (eq ordenar 'titulo_desc' )}}selected{{/if}}>Z — A</option>
            </select>
            <div class="flex gap-2">
                <button type="submit"
                    class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition">
                    Buscar
                </button>
                <a href="/catalogo"
                    class="border border-gray-200 hover:bg-gray-50 text-gray-600 text-sm font-semibold px-5 py-2.5 rounded-xl transition">
                    Limpiar
                </a>
            </div>
        </form>

        <!-- Grid -->
        {{#if libros.length}}
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-5">
            {{#each libros}}
            <a href="/catalogo/{{ id_libros }}"
                class="group bg-white rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-lg transition-all duration-300 overflow-hidden flex flex-col hover:-translate-y-1">

                <!-- Portada -->
                <div class="relative aspect-[2/3] overflow-hidden bg-gray-100">
                    {{#if portada}}
                    <img src="{{ portada }}" alt="{{ titulo_libros }}"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                    {{else}}
                    <div class="w-full h-full flex flex-col items-center justify-center text-gray-300">
                        <div class="text-4xl mb-1">📕</div>
                        <p class="text-xs">Sin portada</p>
                    </div>
                    {{/if}}
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-3">
                        <span
                            class="text-white text-xs font-semibold bg-blue-600 px-3 py-1.5 rounded-lg w-full text-center">
                            Ver detalle →
                        </span>
                    </div>
                </div>

                <!-- Info -->
                <div class="p-3 flex flex-col flex-1">
                    <h3
                        class="font-semibold text-gray-900 text-xs leading-snug mb-1 line-clamp-2 group-hover:text-blue-600 transition-colors">
                        {{ titulo_libros }}
                    </h3>
                    {{#if autores}}
                    <p class="text-gray-400 text-xs truncate">{{ autores }}</p>
                    {{/if}}
                </div>

            </a>
            {{/each}}
        </div>
        {{else}}
        <div class="text-center py-24">
            <div class="w-20 h-20 bg-gray-100 rounded-2xl flex items-center justify-center text-4xl mx-auto mb-4">📭
            </div>
            <p class="text-gray-600 font-semibold">No se encontraron libros</p>
            <p class="text-gray-400 text-sm mt-1">Intenta con otros filtros</p>
            <a href="/catalogo" class="mt-4 inline-block text-blue-600 hover:underline text-sm">Ver todos</a>
        </div>
        {{/if}}

    </div>
</div>