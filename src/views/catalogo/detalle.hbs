<div class="min-h-screen bg-gray-50">

    <div class="max-w-5xl mx-auto px-4 py-8">

        <a href="/catalogo"
            class="inline-flex items-center gap-2 text-sm font-medium text-gray-500 hover:text-gray-900 transition mb-8">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Volver al catálogo
        </a>

        <div class="bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm">
            <div class="md:flex">

                <!-- Portada -->
                <div
                    class="md:w-72 lg:w-80 flex-shrink-0 bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center p-10">
                    {{#if libro.portada}}
                    <img src="{{ libro.portada }}" alt="{{ libro.titulo_libros }}"
                        class="w-full rounded-2xl shadow-xl object-cover" />
                    {{else}}
                    <div class="text-center text-gray-300">
                        <div class="text-8xl mb-3">📕</div>
                        <p class="text-sm">Sin portada</p>
                    </div>
                    {{/if}}
                </div>

                <!-- Info -->
                <div class="p-8 lg:p-10 flex-1 flex flex-col justify-between">
                    <div>
                        <!-- Categorias -->
                        {{#if libro.categorias}}
                        <div class="flex flex-wrap gap-2 mb-4">
                            <span class="text-xs bg-blue-50 text-blue-600 px-3 py-1 rounded-full font-medium">
                                {{ libro.categorias }}
                            </span>
                        </div>
                        {{/if}}

                        <h1 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-3 leading-tight">
                            {{ libro.titulo_libros }}
                        </h1>

                        {{#if libro.autores}}
                        <p class="text-blue-600 font-semibold mb-1 text-sm">{{ libro.autores }}</p>
                        {{/if}}
                        {{#if libro.anio_publicacion_libros}}
                        <p class="text-gray-400 text-sm mb-5">{{ libro.anio_publicacion_libros }}</p>
                        {{/if}}

                        <!-- Stats -->
                        <div class="flex gap-6 mb-6 p-4 bg-gray-50 rounded-2xl">
                            <div class="text-center">
                                <div class="text-2xl font-extrabold text-blue-600">{{ libro.total_descargas }}</div>
                                <div class="text-xs text-gray-400 mt-0.5">Descargas</div>
                            </div>
                            <div class="w-px bg-gray-200"></div>
                            <div class="text-center">
                                <div class="text-2xl font-extrabold text-green-600">{{ libro.total_visualizaciones }}
                                </div>
                                <div class="text-xs text-gray-400 mt-0.5">Lecturas</div>
                            </div>
                        </div>

                        {{#if libro.descripcion_libros}}
                        <p class="text-gray-600 text-sm leading-relaxed mb-6">{{ libro.descripcion_libros }}</p>
                        {{/if}}

                        <p class="text-xs text-gray-400 mb-8">
                            Subido por <span class="font-semibold text-gray-600">{{ libro.subido_por }}</span>
                        </p>
                    </div>

                    <!-- Botones -->
                    <div class="flex flex-wrap gap-3">
                        <a href="/catalogo/{{ libro.id_libros }}/leer"
                            class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-xl transition shadow-sm shadow-blue-200 text-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                            </svg>
                            Leer en línea
                        </a>
                        <a href="/catalogo/{{ libro.id_libros }}/descargar"
                            class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-xl transition shadow-sm shadow-green-200 text-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Descargar PDF
                        </a>
                    </div>

                </div>
            </div>
        </div>

        <!-- Libros relacionados -->
        {{#if relacionados.length}}
        <div class="mt-12">
            <h2 class="text-lg font-bold text-gray-900 mb-5">También te puede interesar</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                {{#each relacionados}}
                <a href="/catalogo/{{ id_libros }}"
                    class="group bg-white rounded-2xl border border-gray-100 hover:border-blue-200 hover:shadow-md transition overflow-hidden hover:-translate-y-1 duration-300">
                    <div class="aspect-[2/3] overflow-hidden bg-gray-100">
                        {{#if portada}}
                        <img src="{{ portada }}" alt="{{ titulo_libros }}"
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        {{else}}
                        <div class="w-full h-full flex items-center justify-center text-3xl text-gray-300">📕</div>
                        {{/if}}
                    </div>
                    <div class="p-3">
                        <p
                            class="text-xs font-semibold text-gray-800 line-clamp-2 group-hover:text-blue-600 transition-colors">
                            {{ titulo_libros }}
                        </p>
                        {{#if autores}}
                        <p class="text-xs text-gray-400 mt-1 truncate">{{ autores }}</p>
                        {{/if}}
                    </div>
                </a>
                {{/each}}
            </div>
        </div>
        {{/if}}

    </div>
</div>